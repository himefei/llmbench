{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llmbench",
  "compatibility_date": "2026-04-02",
  "pages_build_output_dir": "dist",
  // Configure D1 and KV bindings in the Cloudflare Pages dashboard.
  // Once you have real resource IDs and need Wrangler-managed bindings,
  // add the d1_databases / kv_namespaces blocks back with valid IDs.
  "vars": {
    "SESSION_TTL_HOURS": "24",
    "ADMIN_IP_BLOCKLIST": ""
  }
}