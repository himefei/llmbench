{
  "name": "llmbench-pages",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cf:dev": "vite build && wrangler pages dev dist",
    "cf:deploy": "vite build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply llmbench --local",
    "db:migrate:remote": "wrangler d1 migrations apply llmbench --remote"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "wrangler": "^4.8.1"
  }
}